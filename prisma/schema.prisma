generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id         String      @id @default(cuid())
  externalId String?     @unique
  sport      Sport
  league     String
  homeTeam   String
  awayTeam   String
  homeScore  Int?
  awayScore  Int?
  status     EventStatus
  startTime  DateTime
  venue      String?
  streamUrl  String?
  metadata   Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  favorites     String[]
  notifications Boolean  @default(true)
  referralCode  String?  @unique
  createdAt     DateTime @default(now())
}

model BettingPartner {
  id          String  @id @default(cuid())
  name        String
  logoUrl     String?
  bonusText   String
  referralUrl String
  isActive    Boolean @default(false)
  order       Int     @default(0)
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

enum Sport {
  FOOTBALL
  BASKETBALL
  NBA
  BASEBALL
  HOCKEY
  NFL
  RUGBY
  AFL
  VOLLEYBALL
  HANDBALL
  MMA
  F1
  CS2
  LOL
  DOTA2
  VALORANT
  ROCKETLEAGUE
}

enum EventStatus {
  UPCOMING
  LIVE
  FINISHED
  CANCELLED
}
